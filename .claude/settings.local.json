      "PowerShell(Start-Process python -ArgumentList \"backend.py\" -WorkingDirectory \"D:\\\\SAR\" -WindowStyle Minimized; Write-Output \"backend started\")",
      "PowerShell(Start-Process npm -ArgumentList \"run\",\"dev\" -WorkingDirectory \"D:\\\\SAR\" -WindowStyle Minimized; Write-Output \"frontend started\")",
      "PowerShell(npm run *)",
      "PowerShell($b = [System.IO.File]::ReadAllBytes\\(\"D:\\\\SAR\\\\launch.bat\"\\); \"Length: $\\($b.Length\\)\"; \"First bytes: \" + \\($b[0..3] -join ','\\); \"BOM EF BB BF? \" + \\($b[0] -eq 0xEF -and $b[1] -eq 0xBB -and $b[2] -eq 0xBF\\))"
