      "PowerShell(cd D:\\\\SAR; Start-Process python -ArgumentList \"proxy.py\" -WindowStyle Minimized; Start-Sleep -Milliseconds 800; $proc = Get-Process python -ErrorAction SilentlyContinue | Sort-Object StartTime -Descending | Select-Object -First 1; \"proxy.py PID: $\\($proc.Id\\)\")",
