{
  "permissions": {
    "allow": [
      "Bash(git push)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/check_refpoints_sync.py\" --hook",
            "statusMessage": "기준점 좌표 동기화 검사"
          }
        ]
      }
    ]
  }
}
