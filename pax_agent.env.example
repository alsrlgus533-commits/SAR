# pax_agent.py 설정 — 회사 내부망 PC에만 둔다(절대 커밋 금지: pax_agent.env)
# 복사해서 pax_agent.env 로 저장 후 값을 채우세요.

# ── 내부 시스템(웹 화면, ID/PW 로그인) ──
INTERNAL_BASE=https://내부시스템주소           # 내부 시스템 기본 URL(끝 슬래시 없이)
INTERNAL_ID=                                    # 내부 시스템 로그인 아이디
INTERNAL_PW=                                    # 내부 시스템 로그인 비밀번호
INTERNAL_LOGIN_PATH=/login                      # 로그인 폼 action 경로
INTERNAL_ID_FIELD=userId                        # 로그인 폼 아이디 input name(개발자도구로 확인)
INTERNAL_PW_FIELD=password                      # 로그인 폼 비밀번호 input name
INTERNAL_LIST_PATH=                             # 선박 목록 표 화면 경로
INTERNAL_DETAIL_PATH=                           # 센터별 상세(승선인원) 화면 경로(없으면 목록과 동일)
# VERIFY_TLS=0                                  # 사내 사설 인증서면 0(인증서 검증 끔)

# ── 클라우드 백엔드(외부망) ──
BACKEND_PAX_URL=https://sarchatbot.duckdns.org/pax   # 운영 백엔드의 /pax 주소(https)
PAX_TOKEN=                                      # 백엔드와 동일한 전송 토큰(.env 의 PAX_TOKEN)

# ── 동작 ──
POLL_INTERVAL=180                               # 조회·전송 주기(초). 기본 3분 — 가볍게
HTTP_TIMEOUT=15
