KOMSA_KEY=
KMA_KEY=
GEMINI_KEY=
ANTHROPIC_KEY=
VWORLD_KEY=
# 파싱은 GEMINI_KEY 우선, 없으면 ANTHROPIC_KEY 사용. 둘 다 없으면 프론트 규칙 파서로 대체
# VWORLD_KEY — 기점(여객선 기항지) 좌표 지오코딩 유틸리티용 (geocode_ports.py / refine_island_coords.py).
#   브이월드(vworld.kr) '지오코더 + 검색 API' 인증키. 서버 런타임은 사용 안 함(기준점 목록은 정적으로 코드에 반영됨)
# GEMINI_MODEL=gemini-2.5-flash
# KOMSA_URL 은 기본값이 있어서 보통 불필요 (공공데이터포털 요청주소가 바뀐 경우에만 지정)
# KOMSA_URL=https://apis.data.go.kr/B551171/passengerShipSpecInfo/getPassengerShipSpecInfo
# PORT=8000

# ── 외부 API 자동 건강검진 (모두 선택 — 기본 24시간 주기로 동작) ──
# HEALTH_WEBHOOK_URL=    # 실패/복구 시 알림 보낼 웹훅(Slack/Discord 호환 {"text":...}). 미설정 시 로그만
# HEALTH_CHECK=1         # 0이면 건강검진 비활성
# HEALTH_INTERVAL=86400  # 검진 주기(초, 최소 300)
# HEALTH_FIRST_DELAY=60  # 기동 후 첫 검진까지 지연(초)
# HEALTH_LOCK_PORT=8401  # gunicorn 다중 워커 중복 검진 방지용 localhost 락 포트

# ── 회사 실시간 여객수 전송 (/pax — 중간 기항지 승하선 반영, 모두 선택) ──
# PAX_TOKEN=             # 전송 인증 토큰(권장). 설정 시 /pax POST·GET에 X-Pax-Token 헤더 또는 body token 필요
# PAX_TTL=64800         # '신선' 기준(초). 이 시간 이내 값만 MTIS보다 우선, 지나면 MTIS로 폴백(기본 18시간)
# PAX_STORE=pax_store.json  # 영속화 파일 경로(기본: 프로젝트 폴더)
