KOMSA_KEY=
KMA_KEY=
GEMINI_KEY=
ANTHROPIC_KEY=
VWORLD_KEY=
# 파싱은 GEMINI_KEY 우선, 없으면 ANTHROPIC_KEY 사용. 둘 다 없으면 프론트 규칙 파서로 대체
# VWORLD_KEY — 기점(여객선 기항지) 좌표 지오코딩 유틸리티용 (geocode_ports.py / refine_island_coords.py).
#   브이월드(vworld.kr) '지오코더 + 검색 API' 인증키. 서버 런타임은 사용 안 함(기준점 목록은 정적으로 코드에 반영됨)
# GEMINI_MODEL=gemini-2.5-flash
# KOMSA_URL 은 기본값이 있어서 보통 불필요 (공공데이터포털 요청주소가 바뀐 경우에만 지정)
# KOMSA_URL=https://apis.data.go.kr/B551171/passengerShipSpecInfo/getPassengerShipSpecInfo
# PORT=8000
